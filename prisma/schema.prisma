generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int     @id @default(autoincrement())
  username String  @unique
  password String
  scores   Score[]
}

model Score {
  id     Int  @id @default(autoincrement())
  value  Int  @default(0)
  user   User @relation(fields: [userId], references: [id])
  userId Int
  createdAt DateTime @default(now())
}
